{
  "name": "vite-react-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts --environment jsdom",
    "test:watch": "vitest --config vitest.config.ts --environment jsdom",
    "test:e2e": "playwright test",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" playwright.config.ts vitest.config.ts tsconfig.json package.json index.html vite.config.js src/index.css",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "serve": "npm run build && npm run preview"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.49.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.22",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.10"
  }
}
